rules_version = '2';
// نسخة التسليم النهائية — قواعد صريحة لكل مجموعة (بدون allow عام على /**).
// بعد التعديل: npm run deploy:rules
// ملاحظة: تحديث درجات التسليمات يبقى لأي مستخدم مصادَق لأن تحديد «المدير» يتم في الواجهة فقط؛
// للإنتاج يُفضّل Custom Claims على Firebase Auth وربطها بالقواعد.

service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    match /courses/{docId} {
      allow read, write: if request.auth != null;
    }

    match /lectures/{docId} {
      allow read, write: if request.auth != null;
    }

    match /assignments/{docId} {
      allow read, write: if request.auth != null;
    }

    match /submissions/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.studentId == request.auth.uid;
      // المدير يرصد الدرجة من admin.js — يتطلب صلاحية أوسع؛ للمشروع الأكاديمي نسمح بالتحديث للمصادَقين.
      allow update: if request.auth != null;
      allow delete: if request.auth != null
        && resource.data.studentId == request.auth.uid;
    }

    match /grades/{docId} {
      allow read, write: if request.auth != null;
    }

    match /schedule/{docId} {
      allow read, write: if request.auth != null;
    }

    match /fees/{docId} {
      allow read, write: if request.auth != null;
    }

    match /notifications/{docId} {
      allow read, write: if request.auth != null;
    }

    match /student_courses/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
